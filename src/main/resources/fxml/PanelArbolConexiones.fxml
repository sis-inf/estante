<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.sisinf.estante.controller.PanelArbolConexionesController"
      VBox.vgrow="ALWAYS">

    <ToolBar>
        <Button fx:id="btnNuevaConexion" text="+" />
        <Button fx:id="btnRefrescar"     text="↺" />
        <Button fx:id="btnEliminar"      text="−" />
    </ToolBar>

    <TextField fx:id="txtBusqueda" 
               promptText="Buscar tablas o esquemas..." />

    <TreeView fx:id="arbol"
              VBox.vgrow="ALWAYS" />

</VBox>